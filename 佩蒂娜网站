<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pretty & Na | 轻奢珠宝品牌</title>
    <meta name="description" content="Pretty & Na — 精致轻奢珠宝，为每一个闪耀时刻而生。银饰、黄金、钻石系列，专属定制。">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap');
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --gold: #C9A96E;
            --gold-light: #E8D5A3;
            --dark: #1A1A1A;
            --cream: #FAF7F2;
            --white: #FFFFFF;
            --gray: #6B6B6B;
            --light-gray: #E8E4DF;
        }
        
        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', -apple-system, sans-serif;
            颜色：var(--dark);
            背景：var(--cream);
            行高：1.8;
            水平溢出：隐藏;
        }
        
/* 导航 */
        nav {
            位置：固定;
            顶部：0;
            width: 100%;
            padding: 20px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            transition: all 0.4s ease;
            background: transparent;
        }
        
        nav.scrolled {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            box-shadow: 0 2px 30px rgba(0,0,0,0.08);
            padding: 15px 60px;
        }
        
        .logo {
            display: block;
            height: 40px;
            width: auto;
            text-decoration: none;
        }
        
        .logo img {
            height: 40px;
            width: auto;
            object-fit: contain;
        }
        
        .nav-links {
            display: flex;
            gap: 40px;
            list-style: none;
        }
        
        .nav-links a {
            text-decoration: none;
            color: var(--dark);
            font-size: 14px;
            letter-spacing: 2px;
            position: relative;
            transition: color 0.3s;
        }
        
        .nav-links a:hover { color: var(--gold); }
        
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--gold);
            transition: width 0.3s;
        }
        
        .nav-links a:hover::after { width: 100%; }
        
        .mobile-menu {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
        }
        
        .mobile-menu span {
            width: 25px;
            height: 2px;
            background: var(--dark);
            transition: 0.3s;
        }
        
        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            background: linear-gradient(135deg, #FAF7F2 0%, #F5EDE0 50%, #FAF7F2 100%);
            overflow: hidden;
        }
        
        .hero::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            border: 1px solid var(--gold-light);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            opacity: 0.3;
            animation: pulse 4s ease-in-out infinite;
        }
        
        .hero::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            border: 1px solid var(--gold-light);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            opacity: 0.2;
            animation: pulse 4s ease-in-out infinite 1s;
        }
        
        @keyframes pulse {
            0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.3; }
            50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.15; }
        }
        
        .hero-content {
            position: relative;
            z-index: 1;
        }
        
        .hero-subtitle {
            font-size: 13px;
            letter-spacing: 8px;
            color: var(--gold);
            margin-bottom: 30px;
            text-transform: uppercase;
        }
        
        .hero-title {
            font-family: 'Playfair Display', 'Georgia', serif;
            font-size: 72px;
            font-weight: 400;
            letter-spacing: 12px;
            margin-bottom: 30px;
            background: linear-gradient(135deg, var(--dark) 0%, var(--gold) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .hero-desc {
            font-size: 16px;
            color: var(--gray);
            letter-spacing: 3px;
            margin-bottom: 50px;
            font-weight: 300;
        }
        
        .cta-button {
            display: inline-block;
            padding: 18px 50px;
            background: var(--gold);
            color: var(--white);
            text-decoration: none;
            font-size: 13px;
            letter-spacing: 4px;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }
        
        .cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.6s;
        }
        
        .cta-button:hover::before { left: 100%; }
        
        .cta-button:hover {
            background: var(--dark);
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        
        /* Section Common */
        section {
            padding: 120px 60px;
        }
        
        .section-title {
            font-size: 36px;
            font-weight: 200;
            letter-spacing: 8px;
            text-align: center;
            margin-bottom: 20px;
            color: var(--dark);
        }
        
        .section-subtitle {
            text-align: center;
            color: var(--gold);
            font-size: 13px;
            letter-spacing: 6px;
            margin-bottom: 60px;
        }
        
        .divider {
            width: 60px;
            height: 1px;
            background: var(--gold);
            margin: 0 auto 60px;
        }
        
        /* Brand Story */
        .brand-story {
            background: var(--white);
        }
        
        .brand-content {
            max-width: 800px;
            margin: 0 auto;
            text-align: center;
        }
        
        .brand-quote {
            font-size: 24px;
            font-weight: 300;
            color: var(--dark);
            line-height: 2;
            margin-bottom: 40px;
            font-style: italic;
        }
        
        .brand-quote::before { content: '"'; color: var(--gold); font-size: 40px; }
        .brand-quote::after { content: '"'; color: var(--gold); font-size: 40px; }
        
        .brand-text {
            font-size: 15px;
            color: var(--gray);
            line-height: 2.2;
            letter-spacing: 1px;
        }
        
        /* Collections */
        .collections {
            background: var(--cream);
        }
        
        .collection-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .collection-card {
            position: relative;
            height: 500px;
            background: var(--white);
            overflow: hidden;
            cursor: pointer;
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }
        
        .collection-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        }
        
        .card-image {
            width: 100%;
            height: 70%;
            background: linear-gradient(135deg, #F5EDE0 0%, #E8D5A3 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        
        .card-icon {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        
        .card-image::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 50%;
            background: linear-gradient(to top, rgba(255,255,255,0.8), transparent);
        }
        
        .card-info {
            padding: 25px;
            text-align: center;
        }
        
        .card-name {
            font-size: 18px;
            letter-spacing: 4px;
            margin-bottom: 8px;
            color: var(--dark);
        }
        
        .card-desc {
            font-size: 13px;
            color: var(--gray);
            letter-spacing: 1px;
        }
        
        /* Features */
        .features {
            background: var(--dark);
            color: var(--white);
        }
        
        .features .section-title { color: var(--white); }
        
        .feature-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 60px;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .feature-item {
            text-align: center;
            padding: 40px 20px;
            border: 1px solid rgba(201, 169, 110, 0.2);
            transition: all 0.3s ease;
        }
        
        .feature-item:hover {
            border-color: var(--gold);
            background: rgba(201, 169, 110, 0.05);
        }
        
        .feature-icon {
            font-size: 40px;
            margin-bottom: 25px;
        }
        
        .feature-name {
            font-size: 16px;
            letter-spacing: 4px;
            margin-bottom: 15px;
            color: var(--gold-light);
        }
        
        .feature-desc {
            font-size: 14px;
            color: rgba(255,255,255,0.6);
            line-height: 1.8;
        }
        
        /* Testimonials */
        .testimonials {
            background: var(--white);
        }
        
        .testimonial-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
            max-width: 1100px;
            margin: 0 auto;
        }
        
        .testimonial-card {
            padding: 40px;
            background: var(--cream);
            position: relative;
        }
        
        .testimonial-card::before {
            content: '"';
            font-size: 80px;
            color: var(--gold-light);
            position: absolute;
            top: 10px;
            left: 20px;
            line-height: 1;
        }
        
        .testimonial-text {
            font-size: 14px;
            color: var(--gray);
            line-height: 2;
            margin-bottom: 25px;
            padding-top: 30px;
        }
        
        .testimonial-author {
            font-size: 13px;
            color: var(--gold);
            letter-spacing: 2px;
        }
        
        /* Contact */
        .contact {
            background: var(--cream);
            text-align: center;
        }
        
        .contact-info {
            display: flex;
            justify-content: center;
            gap: 80px;
            margin-top: 60px;
        }
        
        .contact-item {
            text-align: center;
        }
        
        .contact-label {
            font-size: 13px;
            color: var(--gold);
            letter-spacing: 4px;
            margin-bottom: 10px;
        }
        
        .contact-value {
            font-size: 16px;
            color: var(--dark);
            letter-spacing: 1px;
        }
        
        /* Footer */
        footer {
            background: var(--dark);
            color: rgba(255,255,255,0.4);
            padding: 60px;
            text-align: center;
        }
        
        .footer-logo {
            height: 36px;
            width: auto;
            margin-bottom: 30px;
            display: inline-block;
            color: var(--white);
        }
        
        .footer-logo img {
            height: 36px;
            width: auto;
            object-fit: contain;
        }
        
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin-bottom: 40px;
        }
        
        .footer-links a {
            color: rgba(255,255,255,0.4);
            text-decoration: none;
            font-size: 13px;
            letter-spacing: 2px;
            transition: color 0.3s;
        }
        
        .footer-links a:hover { color: var(--gold); }
        
        .footer-copy {
            font-size: 12px;
            letter-spacing: 1px;
        }
        
        /* Animations */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }
        
        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* Responsive */
        @media (max-width: 1024px) {
            .collection-grid { grid-template-columns: repeat(2, 1fr); }
            .feature-grid { grid-template-columns: repeat(2, 1fr); }
        }
        
        @media (max-width: 768px) {
            nav { padding: 15px 25px; }
            nav.scrolled { padding: 12px 25px; }
            .nav-links { display: none; }
            .mobile-menu { display: flex; }
            .hero-title { font-size: 42px; letter-spacing: 6px; }
            section { padding: 80px 25px; }
            .collection-grid { grid-template-columns: 1fr; }
            .collection-card { height: 400px; }
            .feature-grid { grid-template-columns: 1fr; gap: 30px; }
            .testimonial-grid { grid-template-columns: 1fr; }
            .contact-info { flex-direction: column; gap: 40px; }
            .footer-links { flex-direction: column; gap: 20px; }
        }
    </style>
</head>
